# twitterapi.io API key — 在 https://twitterapi.io/dashboard 获取
TWITTERAPI_IO_KEY=your_key_here

# DeepSeek V4 (OpenAI 兼容) —— 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# 邮件发送 provider（二选一）：
#   EMAIL_PROVIDER=mcp      → 走本机 email-mcp（仅 macOS 本机，云端 SMTP 通常被封）
#   EMAIL_PROVIDER=resend   → 走 Resend HTTPS API（云端部署推荐）
#   EMAIL_PROVIDER=         → 留空则跳过发送
EMAIL_PROVIDER=
DIGEST_TO=you@example.com

# --- EMAIL_PROVIDER=resend 时用 ---
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM=onboarding@resend.dev   # 自有域名验证后换成 digest@yourdomain.com

# --- EMAIL_PROVIDER=mcp 时用 ---
EMAIL_MCP_ACCOUNT=work
